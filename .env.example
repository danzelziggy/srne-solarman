# Example .env for docker-compose.tailscale.yml and docker-compose.tailscale.windows.yml
# Copy this to .env and replace the TS_AUTHKEY value with a valid key
# Get your auth key from: https://login.tailscale.com/admin/settings/keys

# REQUIRED: Tailscale authentication key
TS_AUTHKEY=tskey-auth-kREPLACE_WITH_YOUR_KEY

# OPTIONAL: Hostname for your Tailscale device
TS_HOSTNAME=homeassistant

# OPTIONAL: Extra arguments passed to tailscale on startup
TS_EXTRA_ARGS=
